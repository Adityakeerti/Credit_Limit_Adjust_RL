# ─────────────────────────────────────────────────────────────────────────────
# AutoLend Environment Variables — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (use Neon.tech for free managed Postgres) ──────────────────────
POSTGRES_URL=jdbc:postgresql://<neon-host>/autolend?sslmode=require
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Valkey / Redis-compatible cache (use Upstash for free serverless) ─────────
# Valkey is an open-source Redis fork — 100% compatible with spring-data-redis
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_SSL=false

# ── Kafka (use Upstash Kafka for free serverless Kafka) ───────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# Set to SASL_SSL when using Upstash; leave as PLAINTEXT for local
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=YXJ0aGFjb3JlLWF1dG9sZW5kLXNlY3JldC1rZXktZm9yLWp3dC1zaWduaW5nLTIwMjY=
JWT_EXPIRATION=86400000

# ── Backend server ────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Frontend (Vercel / Nginx) ─────────────────────────────────────────────────
# Uncomment and set when the frontend needs to call a live backend
# VITE_API_URL=https://your-backend.koyeb.app
